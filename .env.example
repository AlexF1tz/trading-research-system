# Stage 2 uses the real, read-only Alpaca historical-bars provider.
MARKET_DATA_PROVIDER=alpaca_historical_bars

# Copy this file to .env, then set these locally. Never commit values.
# The historical-quality command uses market-data GET requests only.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Unimplemented optional adapters. Leave blank.
MASSIVE_API_KEY=
SEC_USER_AGENT=
